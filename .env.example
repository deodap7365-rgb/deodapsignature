# Copy this file to .env and adjust as needed. All values are optional for local dev.

# Port the server listens on
PORT=3000

# Public base URL used to build signing links in emails (set this when deployed)
APP_URL=http://localhost:3000

# Secret used to sign session tokens. CHANGE THIS in production (any long random string).
JWT_SECRET=change-me-to-a-long-random-string

# --- Email delivery ---
# If SMTP_HOST is left blank, the app runs in DEV email mode: it does NOT send real
# emails. Instead, signing links are printed to the server console AND returned by the
# API / shown in the dashboard so you can test the full flow without a mail server.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="DeoDap eSign <no-reply@deodap.local>"

# Storage locations (defaults are fine)
# DATA_DIR=./data
# UPLOAD_DIR=./uploads
